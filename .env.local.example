# Look-see local-development env file.
# Usage: cp .env.local.example .env  (then `docker compose up --build`).

# ---------- Spring profile ----------
# `local` activates LocalSecurityConfig (Auth0 bypass) in CrawlerAPI and loads
# application-local.properties. Unset to use real Auth0.
SPRING_PROFILES_ACTIVE=local

# ---------- Neo4j ----------
NEO4J_BOLT_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE_NAME=neo4j

# ---------- GCP / Pub/Sub emulator ----------
PROJECT_ID=looksee-local
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
GCP_CREDENTIALS_LOCATION=

# ---------- Pub/Sub topic names ----------
URL_TOPIC=url-topic
PAGE_AUDIT_TOPIC=page-audit-topic
AUDIT_UPDATE_TOPIC=audit-update-topic
ERROR_TOPIC=audit-error-topic
PAGE_CREATED_TOPIC=page-created-topic
JOURNEY_VERIFIED_TOPIC=journey-verified-topic
JOURNEY_DISCARDED_TOPIC=journey-discarded-topic
JOURNEY_CANDIDATE_TOPIC=journey-candidate-topic
ELEMENT_EXTRACTION_TOPIC=element-extraction-topic
JOURNEY_MAP_CLEANUP_TOPIC=journey-map-cleanup-topic

# ---------- LookseeCore ----------
LOOKSEE_CORE_VERSION=1.1.0

# ---------- UI ----------
LOCAL_STACK=1
AUTH0_API_URI=http://localhost:9080
AUTH0_APP_URI=http://localhost:4200
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
