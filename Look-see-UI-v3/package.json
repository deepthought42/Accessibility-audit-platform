{
  "name": "A11yUserInterface",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "bash scripts/generate-env-local.sh && bash scripts/generate-config-local.sh && ng serve",
    "start:direct": "ng serve",
    "build": "bash scripts/generate-env-local.sh && bash scripts/generate-config-local.sh && ng build",
    "build:direct": "ng build",
    "watch": "bash scripts/generate-env-local.sh && bash scripts/generate-config-local.sh && ng build --watch --configuration development",
    "test": "bash scripts/generate-env-local.sh && bash scripts/generate-config-local.sh && CHROME_BIN=${CHROME_BIN:-/snap/bin/chromium} ng test --watch=false",
    "test:watch": "bash scripts/generate-env-local.sh && bash scripts/generate-config-local.sh && CHROME_BIN=${CHROME_BIN:-/snap/bin/chromium} ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "load-env": "node scripts/load-env.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "17.3.2",
    "@angular/cdk": "17.3.2",
    "@angular/common": "^17.3.2",
    "@angular/compiler": "17.3.2",
    "@angular/compiler-cli": "17.3.2",
    "@angular/core": "17.3.2",
    "@angular/forms": "17.3.2",
    "@angular/material": "17.3.2",
    "@angular/platform-browser": "17.3.2",
    "@angular/platform-browser-dynamic": "17.3.2",
    "@angular/router": "17.3.2",
    "@auth0/angular-jwt": "^5.2.0",
    "@auth0/auth0-angular": "^2.2.3",
    "@fortawesome/angular-fontawesome": "^0.14.1",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-regular-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "flowbite": "^2.3.0",
    "pusher-js": "^7.6.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^17.0.2",
    "@angular-devkit/build-angular": "17.3.2",
    "@angular/cli": "17.3.2",
    "@google-cloud/secret-manager": "^6.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^10.0.4",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^24.0.10",
    "angular-eslint": "20.1.1",
    "dotenv": "^16.3.1",
    "eslint": "^9.29.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "schematics-scss-migrate": "^1.3.13",
    "semantic-release": "^24.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "typescript-eslint": "8.34.1",
    "webpack": "^5.104.1"
  },
  "release": {
    "branches": [
      "main",
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  }
}
